<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="100dp">

        <!-- Day Counter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header"
            android:padding="30dp"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tv_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_days"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:alpha="0.9"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Motivation Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header"
            android:padding="20dp"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tv_motivation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quote_1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_motivation_default"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:alpha="0.8"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Today Stats Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/today_status"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/gray_700"
                android:layout_marginBottom="12dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@color/pink_50"
                    android:padding="14dp"
                    android:gravity="center"
                    android:layout_margin="5dp">

                    <TextView
                        android:id="@+id/tv_today_smoked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_700" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/unit_cigs"
                        android:textSize="12sp"
                        android:textColor="@color/gray_500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/today_smoked"
                        android:textSize="11sp"
                        android:textColor="@color/gray_400"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@color/pink_50"
                    android:padding="14dp"
                    android:gravity="center"
                    android:layout_margin="5dp">

                    <TextView
                        android:id="@+id/tv_today_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¥0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_700" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/unit_yuan"
                        android:textSize="12sp"
                        android:textColor="@color/gray_500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/today_cost"
                        android:textSize="11sp"
                        android:textColor="@color/gray_400"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@color/pink_50"
                    android:padding="14dp"
                    android:gravity="center"
                    android:layout_margin="5dp">

                    <TextView
                        android:id="@+id/tv_total_saved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¥0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_700" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/unit_yuan"
                        android:textSize="12sp"
                        android:textColor="@color/gray_500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_saved"
                        android:textSize="11sp"
                        android:textColor="@color/gray_400"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@color/pink_50"
                    android:padding="14dp"
                    android:gravity="center"
                    android:layout_margin="5dp">

                    <TextView
                        android:id="@+id/tv_health_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_700" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recovery_label"
                        android:textSize="12sp"
                        android:textColor="@color/gray_500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/health_recovery"
                        android:textSize="11sp"
                        android:textColor="@color/gray_400"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </GridLayout>
        </LinearLayout>

        <!-- Health Timeline Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/health_timeline"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/gray_700"
                android:layout_marginBottom="12dp" />

            <!-- Timeline items -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp">

                <View
                    android:layout_width="2dp"
                    android:layout_height="match_parent"
                    android:background="@color/pink_200"
                    android:layout_marginStart="4dp" />

                <!-- Item 1: 20分钟 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tv_recovery_time_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_20min"
                        android:textSize="11sp"
                        android:textColor="@color/pink_600"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_20min_desc"
                        android:textSize="13sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginTop="2dp" />

                    <ProgressBar
                        android:id="@+id/pb_recovery_1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_progress_recovery"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Item 2: 12小时 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tv_recovery_time_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_12h"
                        android:textSize="11sp"
                        android:textColor="@color/pink_600"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_12h_desc"
                        android:textSize="13sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginTop="2dp" />

                    <ProgressBar
                        android:id="@+id/pb_recovery_2"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_progress_recovery"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Item 3: 2-3周 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tv_recovery_time_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_3weeks"
                        android:textSize="11sp"
                        android:textColor="@color/pink_600"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_3weeks_desc"
                        android:textSize="13sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginTop="2dp" />

                    <ProgressBar
                        android:id="@+id/pb_recovery_3"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_progress_recovery"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Item 4: 1-9个月 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tv_recovery_time_4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_9months"
                        android:textSize="11sp"
                        android:textColor="@color/pink_600"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_9months_desc"
                        android:textSize="13sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginTop="2dp" />

                    <ProgressBar
                        android:id="@+id/pb_recovery_4"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_progress_recovery"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Item 5: 1年 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_recovery_time_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_1year"
                        android:textSize="11sp"
                        android:textColor="@color/pink_600"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestone_1year_desc"
                        android:textSize="13sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginTop="2dp" />

                    <ProgressBar
                        android:id="@+id/pb_recovery_5"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_progress_recovery"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Quick Record Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quick_record"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/gray_700"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/record_prompt"
                android:textSize="13sp"
                android:textColor="@color/gray_500"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btn_no_smoke"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_button"
                    android:text="@string/btn_no_smoke"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginEnd="5dp" />

                <Button
                    android:id="@+id/btn_smoked"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_button"
                    android:text="@string/btn_smoked"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="5dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
