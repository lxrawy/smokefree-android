<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_export"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_header" />

    <!-- 日期选择区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/export_select_range"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/gray_700"
            android:layout_marginBottom="20dp" />

        <!-- 开始日期 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/export_start_date"
            android:textSize="13sp"
            android:textColor="@color/gray_600"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_start_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:text="@string/export_start_hint"
            android:textSize="15sp"
            android:textColor="@color/gray_700"
            android:drawableEnd="@android:drawable/arrow_down_float"
            android:layout_marginBottom="14dp" />

        <!-- 结束日期 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/export_end_date"
            android:textSize="13sp"
            android:textColor="@color/gray_600"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_end_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:text="@string/export_end_hint"
            android:textSize="15sp"
            android:textColor="@color/gray_700"
            android:drawableEnd="@android:drawable/arrow_down_float" />

        <!-- 范围信息提示 -->
        <TextView
            android:id="@+id/tv_date_range_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/export_range_hint"
            android:textSize="12sp"
            android:textColor="@color/gray_400"
            android:layout_marginTop="10dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/pink_100" />

    <!-- 导出说明 + 按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/pink_50"
            android:padding="12dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/export_info_note"
                android:textSize="12sp"
                android:textColor="@color/gray_500"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_export_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_primary_button"
            android:text="@string/export_btn"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingVertical="14dp" />
    </LinearLayout>
</LinearLayout>
