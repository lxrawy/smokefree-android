<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Me Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="100dp">

            <!-- Quit Settings -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/quit_settings"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/gray_400"
                android:letterSpacing="0.5"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <!-- Smoking History -->
                <LinearLayout
                    android:id="@+id/layout_smoking_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/smoking_history"
                        android:textSize="14sp"
                        android:textColor="@color/gray_700" />

                    <TextView
                        android:id="@+id/tv_history_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/me_history_not_filled"
                        android:textSize="12sp"
                        android:textColor="@color/gray_400"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="14sp"
                        android:textColor="@color/gray_300" />
                </LinearLayout>

                <!-- History Input Form -->
                <LinearLayout
                    android:id="@+id/layout_history_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/me_daily_cigs_prompt"
                        android:textSize="13sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_daily_cigs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:hint="例如：10"
                        android:inputType="number"
                        android:textSize="15sp"
                        android:textColor="@color/gray_700"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/me_pack_price_prompt"
                        android:textSize="13sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_pack_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:hint="例如：25"
                        android:inputType="number"
                        android:textSize="15sp"
                        android:textColor="@color/gray_700"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/me_years_prompt"
                        android:textSize="13sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_years_smoking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:hint="例如：5"
                        android:inputType="number"
                        android:textSize="15sp"
                        android:textColor="@color/gray_700"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btn_calculate_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_primary_button"
                        android:text="@string/me_view_summary"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingVertical="12dp" />
                </LinearLayout>

                <!-- History Result -->
                <LinearLayout
                    android:id="@+id/layout_history_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/pink_50"
                        android:padding="14dp"
                        android:layout_marginBottom="10dp">

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2">

                            <TextView
                                android:id="@+id/tv_res_daily"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/pink_600"
                                android:gravity="center" />

                            <TextView
                                android:id="@+id/tv_res_years"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/pink_600"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:text="@string/unit_per_day"
                                android:textSize="11sp"
                                android:textColor="@color/gray_500"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:text="@string/unit_year"
                                android:textSize="11sp"
                                android:textColor="@color/gray_500"
                                android:gravity="center" />

                            <TextView
                                android:id="@+id/tv_res_total"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:layout_columnSpan="2"
                                android:text="¥0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/pink_700"
                                android:gravity="center"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:layout_columnSpan="2"
                                android:text="@string/me_total_spent"
                                android:textSize="11sp"
                                android:textColor="@color/gray_500"
                                android:gravity="center" />
                        </GridLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_start_quit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_primary_button"
                        android:text="@string/me_start_quit"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingVertical="12dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/pink_100" />

                <!-- Notification Settings -->
                <LinearLayout
                    android:id="@+id/layout_notification"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏰"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/notification_settings"
                        android:textSize="14sp"
                        android:textColor="@color/gray_700" />

                    <TextView
                        android:id="@+id/tv_timer_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/me_reminder_desc"
                        android:textSize="12sp"
                        android:textColor="@color/gray_400"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="14sp"
                        android:textColor="@color/gray_300" />
                </LinearLayout>

                <!-- Notification Settings Form -->
                <LinearLayout
                    android:id="@+id/layout_notif_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingBottom="16dp">

                    <GridLayout
                        android:id="@+id/grid_timer_options"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="4"
                        android:layout_marginTop="10dp" />

                    <Button
                        android:id="@+id/btn_save_timer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_primary_button"
                        android:text="@string/me_save_reminder"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingVertical="12dp"
                        android:layout_marginTop="16dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Others Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/others"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/gray_400"
                android:letterSpacing="0.5"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:id="@+id/layout_data_export"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/data_export"
                        android:textSize="14sp"
                        android:textColor="@color/gray_700" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/me_export_records"
                        android:textSize="12sp"
                        android:textColor="@color/gray_400"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="14sp"
                        android:textColor="@color/gray_300" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/pink_100" />

                <LinearLayout
                    android:id="@+id/layout_feedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❓"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/help_feedback"
                        android:textSize="14sp"
                        android:textColor="@color/gray_700" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/me_encounter_problem"
                        android:textSize="12sp"
                        android:textColor="@color/gray_400"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="14sp"
                        android:textColor="@color/gray_300" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/pink_100" />

                <LinearLayout
                    android:id="@+id/layout_about_item"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/about"
                        android:textSize="14sp"
                        android:textColor="@color/gray_700" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/version"
                        android:textSize="12sp"
                        android:textColor="@color/gray_400"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="14sp"
                        android:textColor="@color/gray_300" />
                </LinearLayout>
            </LinearLayout>

            <!-- Logout Button -->
            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/pink_500"
                android:text="@string/logout"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingVertical="14dp"
                android:layout_marginTop="24dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
