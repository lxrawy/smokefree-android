<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EE"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ========== 圆环进度卡片 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:gravity="center">

            <!-- Day label + more button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tv_progress_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="第1天"
                    android:textSize="16sp"
                    android:textColor="@color/gray_600" />

                <TextView
                    android:id="@+id/btn_day_selector"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    android:text="⋮"
                    android:textSize="24sp"
                    android:textColor="@color/gray_400"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </RelativeLayout>

            <!-- Circle Progress -->
            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp">

                <!-- Background circle -->
                <View
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_progress_bg" />

                <!-- Progress arc -->
                <View
                    android:id="@+id/progress_arc"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_progress_foreground" />

                <!-- Center content -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_progress_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="80.4%"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_500" />

                    <TextView
                        android:id="@+id/tv_progress_target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="24小時"
                        android:textSize="13sp"
                        android:textColor="@color/gray_500" />
                </LinearLayout>
            </FrameLayout>

            <!-- Status text -->
            <TextView
                android:id="@+id/tv_progress_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="現在我掌控了！"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/gray_700" />
        </LinearLayout>

        <!-- ========== 四宫格数据卡片 ========== -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:columnCount="2"
            android:rowCount="2">

            <!-- 未吸菸時間 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_item"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚩"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tv_smoke_free_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="19小時 21分 24秒"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/pink_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="未吸菸時間"
                    android:textSize="11sp"
                    android:textColor="@color/gray_500" />
            </LinearLayout>

            <!-- 省下的錢 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_item"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tv_money_saved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="¥ 14.17"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/pink_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="省下的錢"
                    android:textSize="11sp"
                    android:textColor="@color/gray_500" />
            </LinearLayout>

            <!-- 挽回的生命 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_item"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tv_life_regained"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="3小時 41分 47秒"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/pink_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="挽回的生命"
                    android:textSize="11sp"
                    android:textColor="@color/gray_500" />
            </LinearLayout>

            <!-- 未吸的香菸 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_item"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚭"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tv_cigarettes_avoided"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="20.2"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/pink_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="未吸的香菸"
                    android:textSize="11sp"
                    android:textColor="@color/gray_500" />
            </LinearLayout>
        </GridLayout>

        <!-- ========== 吸烟历史统计 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="在您吸菸期間："
                android:textSize="15sp"
                android:textColor="@color/gray_600"
                android:layout_marginBottom="16dp" />

            <!-- 已吸的香菸 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">
                
                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_gray_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/tv_hist_cigarettes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="182,500"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已吸的香菸"
                        android:textSize="12sp"
                        android:textColor="@color/gray_500"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 浪費的錢 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_skull_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/tv_hist_money"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¥ 127,749.98"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="浪費的錢"
                        android:textSize="12sp"
                        android:textColor="@color/gray_500"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 損失的生命 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_clock_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/tv_hist_life_lost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3年 10月 14天"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="損失的生命"
                        android:textSize="12sp"
                        android:textColor="@color/gray_500"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

    </LinearLayout>
</ScrollView>
