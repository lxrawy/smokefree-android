<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_donate"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="@color/pink_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="36dp"
            android:paddingBottom="36dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Heart Icon -->
            <TextView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:text="💖"
                android:textSize="56sp"
                android:gravity="center"
                android:background="@drawable/bg_header"
                android:layout_marginBottom="20dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/donate_activity_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/gray_700"
                android:layout_marginBottom="14dp" />

            <!-- Intro -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/donate_intro"
                android:textSize="14sp"
                android:textColor="@color/gray_500"
                android:lineSpacingExtra="3dp"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="24dp" />

            <!-- QR Code Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_card"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/donate_qr_hint"
                    android:textSize="13sp"
                    android:textColor="@color/gray_600"
                    android:layout_marginBottom="14dp" />

                <!-- QR Code Image (placeholder) -->
                <ImageView
                    android:id="@+id/iv_donate_qr"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:background="@color/pink_50"
                    android:contentDescription="@string/donate_qr_hint"
                    android:scaleType="centerInside" />

                <!-- QR Placeholder hint (shown when no image is set) -->
                <TextView
                    android:id="@+id/tv_qr_placeholder"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:gravity="center"
                    android:text="@string/donate_placeholder"
                    android:textSize="12sp"
                    android:textColor="@color/gray_400"
                    android:background="@color/pink_50"
                    android:padding="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/donate_email_hint"
                    android:textSize="12sp"
                    android:textColor="@color/gray_400"
                    android:layout_marginTop="16dp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Thanks note -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/donate_thanks"
                android:textSize="13sp"
                android:textColor="@color/pink_600"
                android:textStyle="bold"
                android:layout_marginTop="28dp"
                android:gravity="center" />

            <!-- Close button -->
            <Button
                android:id="@+id/btn_donate_close"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_primary_button"
                android:text="@string/donate_close"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingVertical="14dp"
                android:layout_marginTop="32dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
